{
  "name": "taskforge-api",
  "version": "1.0.0",
  "description": "TaskForge — team project management REST API (Express 5 + PostgreSQL)",
  "type": "module",
  "imports": {
    "#db/*": "./db/*.js",
    "#middleware/*": "./middleware/*.js",
    "#routes/*": "./routes/*.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:reset": "node db/reset.js",
    "db:seed": "node db/seed.js",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.0.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1"
  }
}
