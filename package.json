{
  "name": "taskforge",
  "version": "1.0.0",
  "description": "Team project-management API: orgs, projects, kanban tasks, notifications.",
  "type": "module",
  "main": "server.js",
  "imports": {
    "#app": "./app.js",
    "#db/*": "./db/*.js",
    "#lib/*": "./lib/*.js",
    "#middleware/*": "./middleware/*.js",
    "#routes/*": "./routes/*.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:reset": "node db/reset.js",
    "db:seed": "node db/seed.js",
    "db:test:start": "sh test/pgtest.sh start",
    "db:test:stop": "sh test/pgtest.sh stop",
    "pretest": "sh test/pgtest.sh start",
    "test": "npm run test:node && npm run test:vitest",
    "test:node": "node --env-file=.env.test --test test/api.test.js",
    "test:vitest": "node --env-file=.env.test node_modules/vitest/vitest.mjs run test/api.vitest.test.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "supertest": "^7.0.0",
    "vitest": "^4.1.10"
  }
}
